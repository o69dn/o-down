<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="o_down.App.Views.DownloadsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:o_down.App.ViewModels"
    xmlns:m="using:o_down.Core.Models">
    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="8">
        <TextBlock Grid.Row="0" Text="Downloads" Style="{StaticResource TitleTextBlockStyle}"/>
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <TextBox Grid.Column="0" PlaceholderText="Paste a link and press Enter"
                     Text="{x:Bind ViewModel.NewLink, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="OnAddKeyDown"/>
            <Button Grid.Column="1" Content="Add" Command="{x:Bind ViewModel.AddLinkCommand}"/>
        </Grid>
        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="m:DownloadItem">
                    <Grid Padding="8" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Bind FilenameHint}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind SourceUrl}" Opacity="0.6" FontSize="12" TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Maximum="1" Value="{x:Bind Progress, Mode=OneWay}"/>
                            <TextBlock FontSize="11" Opacity="0.6">
                                <Run Text="{x:Bind State}"/> · <Run Text="{x:Bind ReceivedBytes}"/> / <Run Text="{x:Bind TotalBytes}"/>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Pause"  Command="{x:Bind ViewModel.PauseCommand, Mode=OneWay}" CommandParameter="{x:Bind}"/>
                        <Button Grid.Column="2" Content="Resume" Command="{x:Bind ViewModel.ResumeCommand, Mode=OneWay}" CommandParameter="{x:Bind}"/>
                        <Button Grid.Column="3" Content="Open"   Command="{x:Bind ViewModel.OpenFolderCommand, Mode=OneWay}" CommandParameter="{x:Bind}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
