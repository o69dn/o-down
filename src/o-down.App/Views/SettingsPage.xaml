<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="o_down.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:o_down.Core.Models">
    <ScrollViewer>
        <StackPanel Padding="16" Spacing="8" MaxWidth="800" HorizontalAlignment="Left">
            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="aria2c executable"   Opacity="0.7"/>
            <TextBox Text="{x:Bind ViewModel.Aria2Path, Mode=OneWay}" IsReadOnly="True"/>
            <TextBlock Text="yt-dlp executable"   Opacity="0.7"/>
            <TextBox Text="{x:Bind ViewModel.YtDlpPath, Mode=OneWay}" IsReadOnly="True"/>
            <TextBlock Text="ffmpeg executable"   Opacity="0.7"/>
            <TextBox Text="{x:Bind ViewModel.FfmpegPath, Mode=OneWay}" IsReadOnly="True"/>
            <TextBlock Text="Data directory"      Opacity="0.7"/>
            <TextBox Text="{x:Bind ViewModel.DataDirectory, Mode=OneWay}" IsReadOnly="True"/>
            <ToggleSwitch Header="Monitor clipboard for links"
                          IsOn="{x:Bind ViewModel.ClipboardMonitorEnabled, Mode=TwoWay}"/>

            <TextBlock Text="Bandwidth profiles" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,16,0,0"/>
            <TextBlock Text="Active profile (applies to running downloads immediately)"
                       Opacity="0.7" TextWrapping="Wrap"/>
            <ComboBox ItemsSource="{x:Bind ViewModel.Profiles}"
                      SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                      MinWidth="280" HorizontalAlignment="Left">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:BandwidthProfile">
                        <TextBlock Text="{x:Bind DisplaySpeed}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Text="{x:Bind ViewModel.ProfileStatusMessage, Mode=OneWay}"
                       Opacity="0.7" FontSize="12"/>

            <TextBlock Text="Custom profiles" Opacity="0.7" Margin="0,8,0,0"/>
            <ListView ItemsSource="{x:Bind ViewModel.Profiles}"
                      SelectionMode="None"
                      MaxHeight="180">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:BandwidthProfile">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Padding="0,4">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind DisplaySpeed}" Opacity="0.7" FontSize="12"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Remove"
                                    Command="{x:Bind ((models:BandwidthProfile), DataContext).RemoveProfileCommand}"
                                    Visibility="{x:Bind IsBuiltIn}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Text="Add a custom profile (values in KB/s, leave empty for unlimited)" Opacity="0.7" Margin="0,8,0,0"/>
            <TextBox Header="Name" Text="{x:Bind ViewModel.NewProfileName, Mode=TwoWay}"/>
            <TextBox Header="Max download speed (KB/s, blank = unlimited)" Text="{x:Bind ViewModel.NewMaxDownloadKbText, Mode=TwoWay}"/>
            <TextBox Header="Max upload speed (KB/s, blank = unlimited)" Text="{x:Bind ViewModel.NewMaxUploadKbText, Mode=TwoWay}"/>
            <Button Content="Add profile" Command="{x:Bind ViewModel.AddProfileCommand}" HorizontalAlignment="Right"/>
        </StackPanel>
    </ScrollViewer>
</Page>
