<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="o_down.App.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:m="using:o_down.Core.Models">
    <Grid Padding="16" RowDefinitions="Auto,*" RowSpacing="8">
        <TextBlock Grid.Row="0" Text="History" Style="{StaticResource TitleTextBlockStyle}"/>
        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="m:DownloadItem">
                    <StackPanel Padding="8">
                        <TextBlock Text="{x:Bind FilenameHint}"/>
                        <TextBlock Text="{x:Bind State}" Opacity="0.6" FontSize="12"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
