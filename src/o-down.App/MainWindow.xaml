<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="o_down.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="o-down">
    <Grid>
        <NavigationView x:Name="NavView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="True"
                        PaneDisplayMode="Left"
                        SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="downloads" Content="Downloads" Icon="Download"/>
                <NavigationViewItem Tag="torrents"  Content="Torrents"  Icon="Globe"/>
                <NavigationViewItem Tag="queue"     Content="Queue"     Icon="List"/>
                <NavigationViewItem Tag="history"   Content="History"   Icon="History"/>
                <NavigationViewItem Tag="sites"     Content="Sites"     Icon="Video"/>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
