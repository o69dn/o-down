tools/yt-dlp/yt-dlp.exe
tools/yt-dlp/yt-dlp_*_win.zip
tools/ffmpeg/*/ffmpeg.exe
tools/ffmpeg/*/ffplay.exe
tools/ffmpeg/*/*.dll
tools/ffmpeg/*/LICENSE
tools/ffmpeg/*/README

# Local app data
*.db
*.db-shm
*.db-wal
*.log
*.session

# OS
Thumbs.db
.DS_Store

# Browser extension icons (not in source)
extensions/*/icons/*.png

# Build output
dist/
